generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "postgresql"
url      = env("DATABASE_URL")
}

enum Role {
ADMIN
PETUGAS
}

model User {
id_user    Int @id @default(autoincrement())
id_stasiun Int?

nama_user String
email     String @unique
password  String

role Role @default(PETUGAS)

created_at DateTime @default(now())
updated_at DateTime @updatedAt

stasiun Stasiun? @relation(fields: [id_stasiun], references: [id_stasiun])

barangMasuk  BarangMasuk[]
barangKeluar BarangKeluar[]
}

model Stasiun {
id_stasiun Int @id @default(autoincrement())

kode_stasiun String @unique
nama_stasiun String

alamat String?
kontak String?

created_at DateTime @default(now())
updated_at DateTime @updatedAt

users        User[]
barangKeluar BarangKeluar[]
}

model Merchandise {
id_merch Int @id @default(autoincrement())

nama_merch String
deskripsi  String?

created_at DateTime @default(now())
updated_at DateTime @updatedAt

stok Stok?

barangMasuk  BarangMasuk[]
barangKeluar BarangKeluar[]
}

model Stok {
id_stok Int @id @default(autoincrement())

id_merch Int @unique

jumlah_stok Int @default(0)

merchandise Merchandise @relation(fields: [id_merch], references: [id_merch], onDelete: Cascade)
}

model KategoriPenggunaan {
id_kategori Int @id @default(autoincrement())

nama_kategori String @unique

barangKeluar BarangKeluar[]
}

model BarangMasuk {
id_masuk Int @id @default(autoincrement())

id_merch Int
id_user  Int

jumlah Int

tanggal_masuk DateTime @default(now())

keterangan String?

merchandise Merchandise @relation(fields: [id_merch], references: [id_merch])

user User @relation(fields: [id_user], references: [id_user])
}

model BarangKeluar {
id_keluar Int @id @default(autoincrement())

id_merch    Int
id_stasiun  Int
id_kategori Int
id_user     Int

jumlah Int

tanggal_keluar DateTime @default(now())

keterangan String?

merchandise Merchandise @relation(fields: [id_merch], references: [id_merch])

stasiun Stasiun @relation(fields: [id_stasiun], references: [id_stasiun])

kategori KategoriPenggunaan @relation(fields: [id_kategori], references: [id_kategori])

user User @relation(fields: [id_user], references: [id_user])
}
